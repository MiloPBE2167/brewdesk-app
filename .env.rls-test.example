# Creds cho scripts/rls-test.mjs — copy sang .env.rls-test (đã gitignore) rồi điền.
# 2 user này tạo tay trên Supabase Dashboard: Authentication > Users > Add user,
# nhớ TICK "Auto Confirm User" để đăng nhập được ngay (không cần verify email).
# Café: seed ít nhất 1 dòng qua SQL Editor, ví dụ:
#   insert into public.cafes (name, address, lat, lng, district)
#   values ('Test Cafe', '1 Test St', 10.77, 106.70, 'Q1');
# (script tự fetch cafe_id, không cần điền ở đây)

RLS_TEST_USER_A_EMAIL=
